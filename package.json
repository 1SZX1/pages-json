{
  "name": "@uni-ku/pages-json",
  "type": "module",
  "version": "0.2.13",
  "packageManager": "pnpm@10.18.0",
  "description": "Define uniapp pages.json dynamically.",
  "author": "Edwin Xu <edwinhuish@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/uni-ku/pages-json",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uni-ku/pages-json.git"
  },
  "bugs": "https://github.com/uni-ku/pages-json/issues",
  "keywords": [
    "uniapp",
    "uni-app",
    "pages.json",
    "macros",
    "definePage"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": "./dist/types/index.d.ts",
    "./global": "./global.d.ts",
    "./client": "./client.d.ts",
    "./*": {
      "import": {
        "types": "./dist/*.d.ts",
        "default": "./dist/*.js"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "*.d.ts",
    "dist"
  ],
  "scripts": {
    "stub": "tsup --watch",
    "dev": "pnpm stub",
    "dev:h5": "cross-env NODE_ENV=development pnpm build && pnpm --filter=./playground dev:h5",
    "dev:mp-weixin": "cross-env NODE_ENV=development pnpm build && pnpm --filter=./playground dev:mp-weixin",
    "build": "tsup",
    "build:h5": "pnpm build && pnpm --filter=./playground build:h5",
    "build:mp-weixin": "pnpm build && pnpm --filter=./playground build:mp-weixin",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc -p . --noEmit",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@antfu/utils": "^0.7.10",
    "@babel/generator": "^7.28.3",
    "@babel/types": "^7.28.2",
    "@uni-helper/uni-env": "^0.2.0",
    "@vue/compiler-sfc": "3.5.13",
    "anymatch": "^3.1.3",
    "ast-kit": "^0.12.2",
    "chokidar": "^3.6.0",
    "comment-json": "^4.4.1",
    "debug": "^4.4.1",
    "fast-glob": "^3.3.3",
    "magic-string": "^0.30.18",
    "proper-lockfile": "^4.1.2",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.16.0",
    "@antfu/utils": "^0.7.7",
    "@babel/generator": "^7.23.6",
    "@babel/traverse": "^7.28.3",
    "@dcloudio/types": "^3.4.19",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^20.19.11",
    "@types/proper-lockfile": "^4.1.4",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "cross-env": "^7.0.3",
    "debug": "^4.3.4",
    "eslint": "^9.34.0",
    "eslint-config-flat-gitignore": "^2.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "magic-string": "^0.30.8",
    "rimraf": "^5.0.10",
    "tsup": "^8.5.0",
    "unplugin": "^1.16.1",
    "vite": "^5.4.19",
    "vitest": "^1.6.1"
  }
}
